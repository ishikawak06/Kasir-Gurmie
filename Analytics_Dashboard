                            { label: 'Efficiency', value: (latestOps?.efficiency_rate || 0).toFixed(1) + '%',
                                change: pctChange(latestOps?.efficiency_rate || 0, prevOps?.efficiency_rate || 0),
                                accent: 'amber' },
                            { label: 'NPS Score', value: latestCust?.nps_score || '—', change: pctChange(
