                let data = getTableData(view);
                if (state.tableSearch) {
                    const q = state.tableSearch.toLowerCase();
                    data = data.filter(row => Object.values(row).some(v => String(v).toLowerCase().includes(q)));
                }
                if (state.sortColumn) {
                    const col = state.sortColumn;
                    data.sort((a, b) => {
                        let va = String(a[col]).replace(/[$,%M]/g, '');
                        let vb = String(b[col]).replace(/[$,%M]/g, '');
                        const na = parseFloat(va);
                        const nb = parseFloat(vb);
                        if (!isNaN(na) && !isNaN(nb)) return state.sortDirection === 'asc' ? na - nb : nb -
                            na;
                        return state.sortDirection === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
                    });
                }
                const totalPages = Math.max(1, Math.ceil(data.length / state.rowsPerPage));
                const page = Math.min(state.tablePage, totalPages);
                state.tablePage = page;
                const start = (page - 1) * state.rowsPerPage;
                const pageData = data.slice(start, start + state.rowsPerPage);

                if (!data.length) {
                    container.innerHTML =
                        '<p style="text-align:center;padding:40px;color:var(--text-muted);">No data to display.</p>';
                    return;
                }
                const columns = Object.keys(data[0] || {});
                const thead = columns.map(col => `
                    <th data-column="${col}">${col} ${state.sortColumn === col ? (state.sortDirection === 'asc' ? '▴' : '▾') : '⇅'}</th>
                `).join('');
                const tbody = pageData.map(row => `<tr>${columns.map(col => `<td>${row[col] ?? '—'}</td>`).join('')}</tr>`)
                    .join('');
                container.innerHTML = `
                    <div class="table-wrapper"><table><thead><tr>${thead}</tr></thead><tbody>${tbody}</tbody></table></div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;flex-wrap:wrap;gap:8px;">
                        <span style="font-size:0.8rem;color:var(--text-muted);">${start+1}–${Math.min(start+state.rowsPerPage, data.length)} of ${data.length}</span>
                        <div class="pagination">
                            <button ${page <= 1 ? 'disabled' : ''} data-page="prev">← Prev</button>
                            <span>Page ${page} / ${totalPages}</span>
                            <button ${page >= totalPages ? 'disabled' : ''} data-page="next">Next →</button>
                        </div>
                    </div>`;
                container.querySelectorAll('th[data-column]').forEach(th => {
                    th.addEventListener('click', () => {
                        const col = th.dataset.column;
                        if (state.sortColumn === col) state.sortDirection = state.sortDirection ===
                            'asc' ? 'desc' : 'asc';
                        else { state.sortColumn = col;
                            state.sortDirection = 'asc'; }
                        state.tablePage = 1;
                        renderDataTable(container, view);
                    });
                });
                container.querySelectorAll('.pagination button[data-page]').forEach(btn => {
                    btn.addEventListener('click', () => {
                        if (btn.disabled) return;
                        if (btn.dataset.page === 'prev') state.tablePage = Math.max(1, state
                            .tablePage - 1);
                        else state.tablePage = Math.min(totalPages, state.tablePage + 1);
                        renderDataTable(container, view);
                    });
                });
            }

            function getChartCanvasHTML(view) {
                switch (view) {
                    case 'executive':
                        return `
                            <div class="charts-grid">
                                <div class="chart-container"><canvas id="chart-exec-1"></canvas></div>
                                <div class="chart-container"><canvas id="chart-exec-2"></canvas></div>
                                <div class="chart-full"><canvas id="chart-exec-3"></canvas></div>
                            </div>`;
                    case 'sales':
                        return `
                            <div class="charts-grid">
                                <div class="chart-container"><canvas id="chart-sales-1"></canvas></div>
                                <div class="chart-container"><canvas id="chart-sales-2"></canvas></div>
                            </div>`;
                    case 'operations':
                        return `
                            <div class="charts-grid">
                                <div class="chart-container"><canvas id="chart-ops-1"></canvas></div>
                                <div class="chart-container"><canvas id="chart-ops-2"></canvas></div>
                            </div>`;
                    case 'financial':
                        return `
                            <div class="charts-grid">
                                <div class="chart-container"><canvas id="chart-fin-1"></canvas></div>
                                <div class="chart-container"><canvas id="chart-fin-2"></canvas></div>
                            </div>`;
                    default:
                        return '';
                }
            }

            function renderView(view) {
                state.currentView = view;
                state.tablePage = 1;
                state.sortColumn = null;
                state.tableSearch = '';
                destroyAllCharts();
                const container = document.getElementById('mainContent');
                const chartHTML = getChartCanvasHTML(view);
                const isDataView = view === 'data-management';
                const isReportsView = view === 'reports';

                document.querySelectorAll('.sidebar-nav button').forEach(b => b.classList.remove('active'));
                const activeBtn = document.querySelector(`.sidebar-nav button[data-view="${view}"]`);
                if (activeBtn) activeBtn.classList.add('active');

                const titles = {
                    executive: 'Executive Overview',
                    sales: 'Sales Analytics',
                    operations: 'Operations Dashboard',
                    financial: 'Financial Performance',
                    'data-management': 'Data Management',
                    reports: 'Reports',
                };
                document.getElementById('viewTitle').textContent = titles[view] || 'Dashboard';

                if (isDataView) {
                    container.innerHTML = `
                        <div class="panel">
                            <div class="panel-header"><h3>📁 Data Management & Import</h3></div>
                            <div class="panel-body">
                                <p style="color:var(--text-secondary);margin-bottom:14px;">Import CSV files from your ERP, CRM, finance tools, or spreadsheets. All data is stored locally.</p>
                                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
                                    <button class="btn btn-primary" id="btnImportCsv2">📥 Import CSV</button>
                                    <button class="btn btn-outline" id="btnLoadSample">🔄 Reload Sample</button>
                                    <button class="btn btn-outline" id="btnClearData">🗑 Clear All</button>
                                </div>
                                <div id="importedDatasetsInfo" style="font-size:0.82rem;color:var(--text-muted);"></div>
                                <div style="margin-top:14px;"><div id="dataMgmtTable"></div></div>
                            </div>
                        </div>`;
                    renderDataTable(document.getElementById('dataMgmtTable'), 'sales');
                    updateImportedDatasetsInfo();
                    document.getElementById('btnImportCsv2')?.addEventListener('click', openImportModal);
                    document.getElementById('btnLoadSample')?.addEventListener('click', () => {
                        generateSampleData();
                        updateImportedDatasetsInfo();
                        renderDataTable(document.getElementById('dataMgmtTable'), 'sales');
                        showToast('success', '✅ Sample data reloaded.');
                    });
                    document.getElementById('btnClearData')?.addEventListener('click', () => {
                        if (confirm('Clear all data?')) {
                            state.salesData = [];
                            state.operationsData = [];
                            state.customerData = [];
                            state.financialData = [];
                            state.importedDatasets = {};
                            updateImportedDatasetsInfo();
                            renderDataTable(document.getElementById('dataMgmtTable'), 'sales');
                            showToast('success', '🗑 All data cleared.');
                        }
                    });
                } else if (isReportsView) {
                    container.innerHTML = `
                        <div class="kpi-row" id="reportsKPIrow"></div>
                        <div class="panel">
                            <div class="panel-header"><h3>📝 Generate Report</h3></div>
                            <div class="panel-body">
                                <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:end;margin-bottom:14px;">
                                    <div><label style="font-size:0.8rem;font-weight:600;">Type</label><br>
                                        <select id="reportType" style="padding:7px 10px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--surface);color:var(--text);">
                                            <option value="executive">Executive Summary</option>
                                            <option value="sales">Sales Performance</option>
                                            <option value="operations">Operational Metrics</option>
                                            <option value="financial">Financial P&L</option>
                                        </select></div>
                                    <div><label style="font-size:0.8rem;font-weight:600;">From</label><br><input type="month" id="reportFrom" value="2024-01" style="padding:7px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--surface);color:var(--text);"></div>
                                    <div><label style="font-size:0.8rem;font-weight:600;">To</label><br><input type="month" id="reportTo" value="2024-12" style="padding:7px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--surface);color:var(--text);"></div>
                                    <button class="btn btn-primary" id="btnGenerateReport">📄 Generate</button>
                                    <button class="btn btn-outline" id="btnExportReport">📥 Export</button>
                                </div>
                                <div id="reportOutput" style="background:var(--surface-alt);border-radius:var(--radius);padding:16px;min-height:100px;font-size:0.85rem;"></div>
                            </div>
                        </div>`;
                    renderKPICards(document.getElementById('reportsKPIrow'), 'executive');
                    document.getElementById('btnGenerateReport')?.addEventListener('click', generateReport);
                    document.getElementById('btnExportReport')?.addEventListener('click', exportReportCSV);
                } else {
                    container.innerHTML = `
                        <div class="kpi-row" id="dashboardKPIrow"></div>
                        <div class="panel">
                            <div class="panel-header"><h3>📊 Charts & Trends</h3><span style="font-size:0.78rem;color:var(--text-muted);">Last 12 months</span></div>
                            <div class="panel-body">${chartHTML}</div>
                        </div>
                        <div class="panel">
                            <div class="panel-header"><h3>📋 Data Table</h3><div class="table-controls"><input type="text" class="search-input" id="tableSearchInput" placeholder="🔍 Search..."></div></div>
                            <div class="panel-body" id="dataTableContainer"></div>
                        </div>`;
                    renderKPICards(document.getElementById('dashboardKPIrow'), view);
                    renderChartsForView(view);
                    renderDataTable(document.getElementById('dataTableContainer'), view);
                    document.getElementById('tableSearchInput')?.addEventListener('input', (e) => {
                        state.tableSearch = e.target.value;
                        state.tablePage = 1;
                        renderDataTable(document.getElementById('dataTableContainer'), view);
                    });
                }
            }

            function updateImportedDatasetsInfo() {
                const div = document.getElementById('importedDatasetsInfo');
                if (!div) return;
                const keys = Object.keys(state.importedDatasets);
                div.innerHTML = keys.length === 0 ? '<p>No external datasets imported.</p>' :
                    '<p><strong>Imported:</strong> ' + keys.map(k =>
                        `<span style="background:var(--primary-light);padding:2px 8px;border-radius:4px;">${k} (${state.importedDatasets[k].length} rows)</span>`
                    ).join(' ') + '</p>';
            }

            function generateReport() {
                const from = document.getElementById('reportFrom')?.value || '2024-01';
                const to = document.getElementById('reportTo')?.value || '2024-12';
                const output = document.getElementById('reportOutput');
                if (!output) return;
                const finFiltered = state.financialData.filter(f => f.month >= from && f.month <= to);
                const totalRev = finFiltered.reduce((a, f) => a + f.total_revenue, 0);
                output.innerHTML = `
                    <p><strong>Period:</strong> ${from} – ${to}</p>
                    <table style="margin-top:8px;width:100%;max-width:400px;">
                        <tr><td>Total Revenue</td><td><strong>$${(totalRev/1e6).toFixed(2)}M</strong></td></tr>
                        <tr><td>Net Profit</td><td><strong>$${(finFiltered.reduce((a,f)=>a+f.net_profit,0)/1e6).toFixed(2)}M</strong></td></tr>
                    </table>`;
                showToast('success', '✅ Report generated.');
            }

            function exportReportCSV() {
                const from = document.getElementById('reportFrom')?.value || '2024-01';
                const to = document.getElementById('reportTo')?.value || '2024-12';
                const csv = Papa.unparse(state.financialData.filter(f => f.month >= from && f.month <= to));
                downloadFile(csv, `report_${from}_${to}.csv`, 'text/csv');
            }

            function openImportModal() {
                document.getElementById('importModal').style.display = 'flex';
                document.getElementById('csvPreview').style.display = 'none';
                document.getElementById('btnConfirmImport').disabled = true;
                state.pendingImportData = null;
                document.getElementById('csvFileInput').value = '';
            }

            function closeImportModal() {
                document.getElementById('importModal').style.display = 'none';
            }

            function handleFileSelect(file) {
                if (!file || !file.name.endsWith('.csv')) {
                    showToast('error', '❌ Invalid CSV file.');
                    return;
                }
                state.pendingImportFile = file;
                Papa.parse(file, {
                    header: true,
                    skipEmptyLines: true,
                    complete: (results) => {
                        if (results.data.length === 0) return;
                        state.pendingImportData = results.data;
                        const preview = document.getElementById('csvPreview');
                        preview.style.display = 'block';
                        const cols = Object.keys(results.data[0]);
                        preview.innerHTML = `<p><strong>${results.data.length} rows</strong>, ${cols.length} columns</p>
                            <table style="font-size:0.75rem;"><thead><tr>${cols.map(c=>`<th>${c}</th>`).join('')}</tr></thead>
                            <tbody>${results.data.slice(0,5).map(r=>`<tr>${cols.map(c=>`<td>${r[c]??'—'}</td>`).join('')}</tr>`).join('')}</tbody></table>`;
                        document.getElementById('btnConfirmImport').disabled = false;
                    },
                });
            }

            function confirmImport() {
                if (!state.pendingImportData) return;
                const mode = document.getElementById('importMode').value;
                const fileName = state.pendingImportFile.name.replace('.csv', '');
                const importedRows = state.pendingImportData;
                const firstRow = importedRows[0] || {};
                if (('revenue' in firstRow || 'Revenue' in firstRow) && ('month' in firstRow || 'Month' in
                        firstRow)) {
                    const mapped = importedRows.map(r => ({
                        month: r.month || r.Month || '',
                        region: r.region || r.Region || 'Unknown',
                        product: r.product || r.Product || 'Unknown',
                        revenue: parseFloat(r.revenue || r.Revenue || 0),
                        units: parseInt(r.units || r.Units || 0),
                        cost: parseFloat(r.cost || r.Cost || 0),
                        profit: parseFloat(r.profit || r.Profit || 0),
                        margin_pct: parseFloat(r.margin_pct || r['Margin %'] || 0),
                    }));
                    state.salesData = mode === 'replace' ? mapped : [...state.salesData, ...mapped];
                    rebuildFinancialData();
                }
                state.importedDatasets[fileName] = importedRows;
                closeImportModal();
                updateImportedDatasetsInfo();
                renderView(state.currentView);
                showToast('success', `✅ Imported ${importedRows.length} rows.`);
            }

            function rebuildFinancialData() {
                const map = {};
                state.salesData.forEach(s => {
                    if (!s.month) return;
                    if (!map[s.month]) map[s.month] = { rev: 0, cost: 0 };
                    map[s.month].rev += s.revenue || 0;
                    map[s.month].cost += s.cost || 0;
                });
                state.financialData = Object.entries(map).sort().map(([month, d]) => {
                    const gp = d.rev - d.cost;
                    const opex = Math.round(d.rev * 0.25);
                    const np = gp - opex;
                    return { month, total_revenue: d.rev, total_cost: d.cost, gross_profit: gp, opex,
                        net_profit: np, net_margin_pct: d.rev > 0 ? Math.round((np / d.rev) * 1000) / 10 :
                            0 };
                });
            }

            function exportCurrentData() {
                const csv = Papa.unparse(getTableData(state.currentView));
                downloadFile(csv, `export_${state.currentView}.csv`, 'text/csv');
                showToast('success', '📥 Data exported.');
            }

            function downloadFile(content, filename, mimeType) {
                const blob = new Blob([content], { type: mimeType });
                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = filename;
                a.click();
                URL.revokeObjectURL(a.href);
            }

            function showToast(type, message) {
                const container = document.getElementById('toastContainer');
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                toast.textContent = message;
                container.appendChild(toast);
                setTimeout(() => {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(120%)';
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }

            function toggleTheme() {
                state.theme = state.theme === 'light' ? 'dark' : 'light';
                document.body.classList.toggle('dark', state.theme === 'dark');
                localStorage.setItem('opspulse-theme', state.theme);
                if (!['data-management', 'reports'].includes(state.currentView)) renderChartsForView(state
                    .currentView);
            }

            function loadTheme() {
                if (localStorage.getItem('opspulse-theme') === 'dark') {
                    state.theme = 'dark';
                    document.body.classList.add('dark');
                }
            }

            function setupEventListeners() {
                document.querySelectorAll('.sidebar-nav button[data-view]').forEach(btn => {
                    btn.addEventListener('click', () => {
                        renderView(btn.dataset.view);
                        document.getElementById('sidebar').classList.remove('open');
                    });
                });
                document.getElementById('themeToggle').addEventListener('click', toggleTheme);
                document.getElementById('btnImportCsv').addEventListener('click', openImportModal);
                document.getElementById('btnExportData').addEventListener('click', exportCurrentData);
                document.getElementById('btnCancelImport').addEventListener('click', closeImportModal);
                document.getElementById('btnConfirmImport').addEventListener('click', confirmImport);
                document.getElementById('importModal').addEventListener('click', e => {
                    if (e.target === e.currentTarget) closeImportModal();
                });
                const dropZone = document.getElementById('dropZone');
                const fileInput = document.getElementById('csvFileInput');
                dropZone.addEventListener('click', () => fileInput.click());
                fileInput.addEventListener('change', e => { if (e.target.files[0]) handleFileSelect(e.target
                        .files[0]); });
                dropZone.addEventListener('dragover', e => { e.preventDefault();
                    dropZone.classList.add('drag-over'); });
                dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
                dropZone.addEventListener('drop', e => {
                    e.preventDefault();
                    dropZone.classList.remove('drag-over');
                    if (e.dataTransfer.files[0]) handleFileSelect(e.dataTransfer.files[0]);
                });
                const mobileBtn = document.getElementById('mobileMenuBtn');
                if (window.innerWidth <= 768) mobileBtn.style.display = 'inline-flex';
                mobileBtn.addEventListener('click', () => document.getElementById('sidebar').classList.toggle(
                    'open'));
                window.addEventListener('resize', () => {
                    mobileBtn.style.display = window.innerWidth <= 768 ? 'inline-flex' : 'none';
                    if (window.innerWidth > 768) document.getElementById('sidebar').classList.remove(
                        'open');
                });
                document.addEventListener('keydown', e => { if (e.key === 'Escape') closeImportModal(); });
            }

            function init() {
                loadTheme();
                generateSampleData();
                setupEventListeners();
                renderView('executive');
            }
            init();
        })();
    </script>
</body>
</html>
