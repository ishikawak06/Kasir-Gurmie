                                    .toFixed(1) + 'M' : '—'), change: pctChange(latestFin?.total_revenue || 0,
                                    prevFin?.total_revenue || 0), accent: 'blue' },
                            { label: 'Net Margin', value: (latestFin?.net_margin_pct || 0).toFixed(1) + '%',
                                change: pctChange(latestFin?.net_margin_pct || 0, prevFin?.net_margin_pct || 0),
                                accent: 'green' },
                            { label: 'Active Customers', value: latestCust ? (latestCust.total_active)
