                        ];
                    case 'sales':
                        const totalSalesRev = state.salesData.reduce((a, s) => a + s.revenue, 0);
                        const totalUnits = state.salesData.reduce((a, s) => a + s.units, 0);
                        const avgMargin = state.salesData.length ? Math.round(state.salesData.reduce((a, s) => a +
