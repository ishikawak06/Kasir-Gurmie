            function generateSampleData() {
                const regions = ['North America', 'Europe', 'Asia Pacific', 'Latin America'];
                const products = ['Enterprise Suite', 'Professional', 'Starter', 'Add-ons', 'Services'];
                const months = [
                    '2024-01', '2024-02', '2024-03', '2024-04', '2024-05', '2024-06',
                    '2024-07', '2024-08', '2024-09', '2024-10', '2024-11', '2024-12'
                ];
                const salesData = [];
                const baseRevenue = { 'Enterprise Suite': 420000, 'Professional': 280000, 'Starter': 140000,
                    'Add-ons': 85000, 'Services': 190000 };
                const baseUnits = { 'Enterprise Suite': 380, 'Professional': 620, 'Starter': 940, 'Add-ons': 1200,
                    'Services': 280 };
                const regionMultiplier = { 'North America': 1.4, 'Europe': 1.0, 'Asia Pacific': 0.85,
                    'Latin America': 0.45 };

                months.forEach((month, mi) => {
                    const seasonality = 1 + 0.15 * Math.sin((mi / 12) * Math.PI * 2);
                    regions.forEach(region => {
                        products.forEach(product => {
                            const base = baseRevenue[product] || 150000;
                            const unitsBase = baseUnits[product] || 500;
                            const mult = regionMultiplier[region] || 1;
                            const noise = 0.85 + Math.random() * 0.3;
                            const revenue = Math.round(base * mult * seasonality * noise);
                            const units = Math.round(unitsBase * mult * seasonality * noise);
                            const cost = Math.round(revenue * (0.35 + Math.random() * 0.2));
                            salesData.push({
                                month,
                                region,
                                product,
                                revenue,
                                units,
                                cost,
                                profit: revenue - cost,
                                margin_pct: Math.round(((revenue - cost) / revenue) * 1000) / 10,
                            });
                        });
                    });
                });
                state.salesData = salesData;

                const opsData = [];
                months.forEach((month, mi) => {
                    const efficiency = Math.round((87 + Math.random() * 8 + (mi * 0.15)) * 10) / 10;
                    const defectRate = Math.round((2.8 - mi * 0.12 + Math.random() * 0.8) * 100) / 100;
                    const throughput = Math.round(1800 + mi * 40 + Math.random() * 300);
                    const downtime = Math.round((14 - mi * 0.5 + Math.random() * 6) * 10) / 10;
                    const fulfillment = Math.round((93.5 + mi * 0.3 + Math.random() * 3.5) * 10) / 10;
                    opsData.push({
                        month,
                        efficiency_rate: Math.min(98, efficiency),
                        defect_rate: Math.max(0.3, defectRate),
                        throughput_units_per_day: throughput,
                        downtime_hours: Math.max(2, downtime),
                        fulfillment_rate: Math.min(99.8, fulfillment),
                    });
                });
                state.operationsData = opsData;

                const custData = [];
                let active = 4200;
                months.forEach((month, mi) => {
                    const newCust = Math.round(180 + Math.random() * 120 + mi * 8);
                    const churned = Math.round(40 + Math.random() * 60 - mi * 1.5);
                    active = active + newCust - churned;
                    const nps = Math.round(42 + mi * 1.2 + Math.random() * 18);
                    custData.push({
                        month,
                        new_customers: newCust,
                        churned_customers: Math.max(15, churned),
                        total_active: active,
                        nps_score: Math.min(78, nps),
                        avg_response_time_hours: Math.round((4.5 - mi * 0.2 + Math.random() * 1.5) * 10) /
                            10,
                    });
                });
                state.customerData = custData;

                const finData = [];
                months.forEach(month => {
                    const totalRevenue = salesData.filter(s => s.month === month).reduce((a, s) => a + s
                        .revenue, 0);
                    const totalCost = salesData.filter(s => s.month === month).reduce((a, s) => a + s.cost,
                    0);
                    const opex = Math.round(totalRevenue * (0.22 + Math.random() * 0.08));
                    finData.push({
                        month,
                        total_revenue: totalRevenue,
                        total_cost: totalCost,
                        gross_profit: totalRevenue - totalCost,
                        opex,
                        net_profit: totalRevenue - totalCost - opex,
                        net_margin_pct: Math.round(((totalRevenue - totalCost - opex) / totalRevenue) *
                            1000) / 10,
                    });
                });
                state.financialData = finData;
            }

            const chartInstances = {};

            function destroyChart(key) {
                if (chartInstances[key]) {
                    chartInstances[key].destroy();
                    delete chartInstances[key];
                }
            }

            function destroyAllCharts() {
                Object.keys(chartInstances).forEach(destroyChart);
            }

            function createChart(canvasId, config) {
                destroyChart(canvasId);
                const canvas = document.getElementById(canvasId);
                if (!canvas) return null;
                const ctx = canvas.getContext('2d');
                const chart = new Chart(ctx, config);
                chartInstances[canvasId] = chart;
                return chart;
            }

