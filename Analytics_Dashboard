                const prevOps = ops.length > 1 ? ops[ops.length - 2] : null;
                const latestCust = cust.length ? cust[cust.length - 1] : null;
                const prevCust = cust.length > 1 ? cust[cust.length - 2] : null;
                const pctChange = (curr, prev) => prev && prev !== 0 ? Math.round(((curr - prev) / Math.abs(prev)) *
                    1000) / 10 : 0;

                switch (view) {
                    case 'executive':
                        return [
