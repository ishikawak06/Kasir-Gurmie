                        const avgDefect = ops.length ? Math.round(ops.reduce((a, o) => a + o.defect_rate, 0) /
                            ops.length * 100) / 100 : 0;
                        return [
                            { label: 'Avg Efficiency', value: avgEff + '%', change: pctChange(latestOps
                                    ?.efficiency_rate || 0, prevOps?.efficiency_rate || 0), accent: 'green' },
                            { label: 'Defect Rate', value: avgDefect + '%', change: pctChange(latestOps
